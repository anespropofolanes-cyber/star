// ── Stories Page ──────────────────────────────────────────────────────

let currentStoryTag = '全部';

function renderStories() {
  const allTags = ['全部', ...new Set(STORIES.flatMap(s => s.tags))];
  const filterBar = document.getElementById('story-filter-bar');
  filterBar.innerHTML = allTags.map(tag =>
    `<button class="story-tag-btn ${tag === currentStoryTag ? 'active' : ''}"
      onclick="filterStories('${tag}')">${tag}</button>`
  ).join('');

  const filtered = currentStoryTag === '全部'
    ? STORIES
    : STORIES.filter(s => s.tags.includes(currentStoryTag));

  const container = document.getElementById('story-list');
  container.innerHTML = `<div class="story-grid">${filtered.map(s => `
    <div class="story-card" onclick="openStory(${s.id})">
      <div class="story-card-head">
        <div class="story-card-gua">
          <span class="story-gua-sym">${s.guaSym}</span>
          <span class="story-gua-name">${s.gua}</span>
        </div>
        <div class="story-card-title">${s.title}</div>
        <div class="story-card-hero">主角：${s.hero}</div>
      </div>
      <div class="story-card-body">
        <div class="story-card-preview">${s.preview}</div>
        <div class="story-card-wisdom">${s.wisdom.slice(0, 55)}…</div>
      </div>
    </div>`).join('')}</div>`;
}

function filterStories(tag) {
  currentStoryTag = tag;
  renderStories();
}

function openStory(id) {
  const s = STORIES.find(s => s.id === id);
  if (!s) return;

  const charHTML = s.characters
    ? `<div class="story-section">
        <div class="story-section-label">相關人物</div>
        <div class="story-char-row">${s.characters.map(c => `<span class="story-char-tag">${c}</span>`).join('')}</div>
      </div>` : '';

  const overlay = document.createElement('div');
  overlay.className = 'story-modal-overlay';
  overlay.innerHTML = `
    <div class="story-modal">
      <div class="story-modal-header">
        <div>
          <div class="story-card-gua" style="margin-bottom:6px">
            <span class="story-gua-sym">${s.guaSym}</span>
            <span class="story-gua-name">${s.gua}</span>
          </div>
          <div class="story-card-title" style="font-size:1.2857em">${s.title}</div>
          <div class="story-card-hero" style="margin-top:4px">主角：${s.hero}</div>
        </div>
        <button class="story-modal-close" onclick="closeStory()">✕</button>
      </div>
      <div class="story-modal-body">
        ${charHTML}
        <div class="story-section">
          <div class="story-section-label">故事</div>
          <div class="story-section-text">${s.story.replace(/\n\n/g, '</div><div class="story-section-text" style="margin-top:10px">')}</div>
        </div>
        <div class="story-section">
          <div class="story-section-label">易經哲理</div>
          <div class="story-wisdom-block">${s.wisdom}</div>
        </div>
        <div class="story-section">
          <div class="story-section-label">今日經典</div>
          <div class="story-section-text" style="font-family:'Noto Serif TC',serif;font-size:1.0em;letter-spacing:0.06em;color:var(--text-mid)">${s.classic}</div>
        </div>
        <div class="story-section">
          <div class="story-char-row">${s.tags.map(t => `<span class="story-char-tag">${t}</span>`).join('')}</div>
        </div>
      </div>
    </div>`;

  overlay.addEventListener('click', e => { if (e.target === overlay) closeStory(); });
  document.body.appendChild(overlay);
}

function closeStory() {
  const overlay = document.querySelector('.story-modal-overlay');
  if (overlay) overlay.remove();
}

// ── Navigation ────────────────────────────────────────────────────────

function navigateTo(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(`page-${page}`).classList.add('active');
  document.querySelector(`.nav-btn[data-page="${page}"]`)?.classList.add('active');

  if (page === 'today') renderToday();
  if (page === 'tasks') renderTaskList();
  if (page === 'diary') renderDiaryPage();
  if (page === 'review') renderReview();
  if (page === 'stories') renderStories();
}

document.querySelectorAll('.nav-btn').forEach(btn => {
  btn.addEventListener('click', () => navigateTo(btn.dataset.page));
});

// ── UI Preferences ────────────────────────────────────────────────────

const FONT_SIZES = [12, 13, 14, 16, 18, 20];
let fontSizeIdx = 2; // default 14px

function changeFontSize(dir) {
  fontSizeIdx = Math.max(0, Math.min(FONT_SIZES.length - 1, fontSizeIdx + dir));
  applyFontSize();
  localStorage.setItem('iching_fontsize', fontSizeIdx);
}

function applyFontSize() {
  document.documentElement.style.setProperty('--fs', FONT_SIZES[fontSizeIdx] + 'px');
}

function toggleFont() {
  const body = document.body;
  const btn = document.getElementById('font-toggle-btn');
  const isSerif = body.classList.toggle('font-serif');
  btn.textContent = isSerif ? '黑' : '明';
  btn.classList.toggle('active', isSerif);
  localStorage.setItem('iching_font', isSerif ? 'serif' : 'sans');
}

function toggleDark() {
  const body = document.body;
  const btn = document.getElementById('dark-toggle-btn');
  const isDark = body.classList.toggle('dark-mode');
  btn.textContent = isDark ? '☀' : '☽';
  btn.classList.toggle('active', isDark);
  localStorage.setItem('iching_dark', isDark ? '1' : '0');
  // Update star brightness
  updateStars(isDark);
}

function restorePrefs() {
  const font = localStorage.getItem('iching_font');
  const dark = localStorage.getItem('iching_dark');
  const sizeIdx = localStorage.getItem('iching_fontsize');
  if (font === 'serif') {
    document.body.classList.add('font-serif');
    const btn = document.getElementById('font-toggle-btn');
    if (btn) { btn.textContent = '黑'; btn.classList.add('active'); }
  }
  if (dark === '1') {
    document.body.classList.add('dark-mode');
    const btn = document.getElementById('dark-toggle-btn');
    if (btn) { btn.textContent = '☀'; btn.classList.add('active'); }
    updateStars(true);
  }
  if (sizeIdx !== null) {
    fontSizeIdx = parseInt(sizeIdx);
    applyFontSize();
  }
}

// ── Stars ─────────────────────────────────────────────────────────────

(function() {
  const canvas = document.getElementById('stars-canvas');
  const ctx = canvas.getContext('2d');
  let stars = [];
  let isDarkMode = false;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function initStars() {
    stars = [];
    const count = Math.floor((canvas.width * canvas.height) / 3500);
    for (let i = 0; i < count; i++) {
      const hue = [220, 240, 280, 260, 200][Math.floor(Math.random() * 5)];
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        r: Math.random() * 1.4 + 0.2,
        a: Math.random() * 0.8 + 0.15,
        speed: Math.random() * 0.4 + 0.05,
        phase: Math.random() * Math.PI * 2,
        hue,
      });
    }
  }

  window.updateStars = function(dark) {
    isDarkMode = dark;
  };

  let t = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    t += 0.008;
    stars.forEach(s => {
      const alpha = s.a * (0.7 + 0.3 * Math.sin(t * s.speed + s.phase));
      if (isDarkMode) {
        // Coloured glowing stars for cosmic mode
        const size = s.r * 1.6;
        const grd = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, size * 2.5);
        grd.addColorStop(0, `hsla(${s.hue},80%,95%,${alpha})`);
        grd.addColorStop(0.4, `hsla(${s.hue},70%,80%,${alpha * 0.5})`);
        grd.addColorStop(1, `hsla(${s.hue},60%,70%,0)`);
        ctx.beginPath();
        ctx.arc(s.x, s.y, size * 2.5, 0, Math.PI * 2);
        ctx.fillStyle = grd;
        ctx.fill();
        // Bright core
        ctx.beginPath();
        ctx.arc(s.x, s.y, size * 0.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${alpha * 0.9})`;
        ctx.fill();
      } else {
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(80,80,70,${alpha * 0.28})`;
        ctx.fill();
      }
    });
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', () => { resize(); initStars(); });
  resize();
  initStars();
  draw();
})();

