  else delete t.doneAt;
  state.tasks[todayDay] = t;
  saveState(state);
  renderStats();
  renderToday();
  renderTaskList();
}

function saveTodayNote() {
  const todayDay = getTodayDay();
  const t = state.tasks[todayDay] || {};
  t.note = document.getElementById('today-note')?.value || '';
  state.tasks[todayDay] = t;
  saveState(state);
}

function saveTodayDiary() {
