const GUA_MAP = {
  '111': { name: '乾', symbol: '☰' },
  '000': { name: '坤', symbol: '☷' },
  '100': { name: '震', symbol: '☳' },
  '011': { name: '巽', symbol: '☴' },
  '010': { name: '坎', symbol: '☵' },
  '101': { name: '離', symbol: '☲' },
  '001': { name: '艮', symbol: '☶' },
  '110': { name: '兌', symbol: '☱' },
};

// ── Render Today Content ──────────────────────────────────────────────

function renderTodayContent(day) {
  const c = CONTENT.find(d => d.day === day);
  const course = COURSE.find(d => d.day === day);
  const sec = document.getElementById('today-content-section');
  if (!c) { sec.innerHTML = ''; return; }

  const stateKey = `interact_${day}`;
  const saved = state[stateKey] || {};
  const saved2 = saved;
  const rich = RICH.find(d => d.day === day);
  const lesson = LESSONS.find(d => d.day === day);

  let interactionHTML = '';
  const it = c.interaction;

  if (it.type === 'choice' && it.options) {
    const opts = it.options.map((o, i) => {
      const sel = saved.choice === i ? 'selected' : '';
      return `<button class="choice-opt ${sel}" onclick="selectChoice(${day},${i},this)">${o}</button>`;
    }).join('');
    interactionHTML = `<div class="choice-grid">${opts}</div>`;
  } else if (it.type === 'lineBuilder') {
    const yao = saved.yao || [1, 1, 1];
    const rows = [2, 1, 0].map(i => {
      const isYang = yao[i];
      return `<div class="yao-toggle">
        <button class="yao-btn" onclick="toggleYao(${day},${i},this)" data-yao="${i}">${isYang ? '—' : '- -'}</button>
        <span class="yao-label">第 ${i + 1} 爻</span>
      </div>`;
    }).join('');
    const key = yao.map(v => v ? '1' : '0').join('');
    const gua = GUA_MAP[key];
    const guaText = gua ? `${gua.symbol} ${gua.name}卦` : '組合中…';
    interactionHTML = `<div class="line-builder">${rows}</div><div class="gua-result" id="gua-result-${day}">${guaText}</div>`;
  } else if (it.type === 'coinToss') {
    const yao = saved.coinYao || [];
    const rows = [0,1,2,3,4,5].map(i => {
      const v = yao[i];
      const label = ['初爻','二爻','三爻','四爻','五爻','上爻'][i];
      const sym = v === undefined ? '' : (v === 1 ? '<span class="coin-yao yang">—</span>' : '<span class="coin-yao yin">- -</span>');
      return `<div class="coin-row-item">
        <button class="coin-throw-btn" onclick="throwCoin(${day},${i})" ${v !== undefined ? 'disabled style="opacity:0.4"' : ''}>擲</button>
        <span style="font-size:0.7143em;color:var(--text-dim);min-width:28px">${label}</span>
        ${sym}
      </div>`;
    }).join('');
    const resetBtn = yao.length === 6 ? `<button class="coin-throw-btn" style="margin-top:6px" onclick="resetCoin(${day})">重置</button>` : '';
    interactionHTML = `<div class="coin-rows">${rows}</div>${resetBtn}`;
  }

  const isOpen = saved.open !== false;

  sec.innerHTML = `
    <div class="section-label" style="margin-top:4px">今日概念</div>
    <div class="content-card">
      <div class="content-card-header" onclick="toggleContent(${day})">
        <div class="content-card-header-left">
          ${c.symbol ? `<span class="content-symbol">${c.symbol}</span>` : ''}
          <div>
            <div class="content-day-label">${c.stage}｜關鍵詞：${c.keyword}</div>
            <div class="content-card-title">${c.title}</div>
          </div>
        </div>
        <span class="content-toggle-icon ${isOpen ? 'open' : ''}" id="content-toggle-${day}">▼</span>
      </div>
      <div class="content-body ${isOpen ? 'open' : ''}" id="content-body-${day}">
        <div class="content-block">
          <div class="content-block-label">今日目標</div>
          <div class="goal-block">${course ? course.goal : ''}</div>
        </div>
        ${rich ? `
        <div class="content-block">
          <div class="content-block-label">今日學習目標</div>
          <div class="goals-list">
            ${(rich.goals || []).map(g => `<div class="goal-item">${g}</div>`).join('')}
          </div>
        </div>
        <div class="content-block">
          <div class="content-block-label">課程內容</div>
          <div class="section-accordion" id="acc-${day}">
            ${(rich.sections || []).map((s, i) => {
              const isCase = s.h.includes('案例');
              const isQuote = s.h.includes('原文') || s.h.includes('翻譯');
              const isOpenDefault = i === 0;
              return '<div class="acc-item' + (isCase ? ' is-case' : '') + (isQuote ? ' is-quote' : '') + '">' +
                '<div class="acc-header" onclick="toggleAcc(this)">' +
                  '<span>' + s.h + '</span>' +
                  '<span class="acc-arrow' + (isOpenDefault ? ' open' : '') + '">▼</span>' +
                '</div>' +
                '<div class="acc-body' + (isOpenDefault ? ' open' : '') + '">' +
                  s.p.map(p => '<div class="acc-para">' + p + '</div>').join('') +
                '</div></div>';
            }).join('')}
          </div>
        </div>
        ${lesson ? `
        <div class="content-block">
          <div class="content-block-label">今日核心觀念</div>
          <div class="content-block-text">${lesson.core}</div>
        </div>
        <div class="content-block">
          <div class="section-accordion">
            <div class="acc-item is-quote">
              <div class="acc-header" onclick="toggleAcc(this)"><span>今日經典</span><span class="acc-arrow">▼</span></div>
              <div class="acc-body">
                <div class="acc-para" style="font-family:'Noto Serif TC',serif;font-size:1.0em;letter-spacing:0.06em">${lesson.classic.text}</div>
                <div style="font-size:0.7143em;color:var(--text-dim);margin-top:6px;font-weight:300">── ${lesson.classic.source}</div>
              </div>
            </div>
            <div class="acc-item is-case">
              <div class="acc-header" onclick="toggleAcc(this)"><span>今日故事｜${lesson.story.name}</span><span class="acc-arrow">▼</span></div>
              <div class="acc-body"><div class="acc-para">${lesson.story.description}</div></div>
            </div>
          </div>
        </div>` : ''}` : `
        <div class="content-block">
          <div class="content-block-label">核心概念</div>
          <div class="content-block-text">${c.coreConcept}</div>
        </div>
        <div class="content-block">
          <div class="content-block-label">生活例子</div>
          <div class="content-block-text">${c.lifeExample}</div>
        </div>`}
        ${rich ? renderRichInteraction(day, rich, saved2) : `
        <div class="content-block">
          <div class="content-block-label">${it.title}</div>
          <div class="content-interaction-desc">${it.instruction}</div>
          ${interactionHTML}
        </div>`}
        <div class="content-block">
          <div class="content-block-label">今日功課</div>
          <div class="content-block-text">${rich ? rich.homework : c.dailyPractice}</div>
        </div>
        <div class="content-block">
          <div class="content-block-label">反思問題</div>
          ${lesson && lesson.journalPrompts ? `
          <div class="goals-list">
            ${lesson.journalPrompts.map(p => `<div class="goal-item">${p}</div>`).join('')}
          </div>` : `<div class="content-block-text">${rich ? rich.reflection : c.reflection}</div>`}
        </div>
        <div class="content-quote-block">${rich ? rich.quote : c.quote}</div>
        ${course && course.practice.length ? `
        <div class="content-block" style="margin-top:18px">
          <div class="content-block-label">今日練習</div>
          <ul class="practice-list">
            ${course.practice.map(p => `<li class="practice-item">${p}</li>`).join('')}
          </ul>
        </div>` : ''}
        ${course && course.quiz ? `
        <div class="content-block">
          <div class="content-block-label">今日測驗</div>
          <div class="quiz-block">
            <div class="quiz-question">${course.quiz.q}</div>
            <div class="quiz-opts" id="quiz-opts-${day}">
              ${course.quiz.opts.map((opt, i) => {
                const isAnswered = saved2 && saved2.quizAnswered;
                const isCorrect = opt === course.quiz.ans;
                const isPicked = saved2 && saved2.quizPick === i;
                let cls = '';
                if (isAnswered) cls = isCorrect ? 'correct' : (isPicked ? 'wrong' : '');
                return `<button class="quiz-opt ${cls}" ${isAnswered ? 'disabled' : ''} onclick="answerQuiz(${day},${i},this)">${opt}</button>`;
              }).join('')}
            </div>
            <div class="quiz-explanation ${saved2 && saved2.quizAnswered ? 'show' : ''}" id="quiz-exp-${day}">${course.quiz.exp}</div>
          </div>
        </div>` : ''}
      </div>
    </div>
  `;
}

function renderRichInteraction(day, rich, saved) {
  const it = rich.it;
  if (!it || !it.type) return '';

  const stateKey = `interact_${day}`;
  let html = '';

  if (it.type === 'multipleChoice') {
    const opts = it.opts || [];
    const isAnswered = saved && saved.richAnswered;
    const picked = saved ? saved.richPick : -1;
    const optHTML = opts.map((o, i) => {
      const text = typeof o === 'object' ? o.t : o;
      const correct = typeof o === 'object' ? o.ok : false;
      let cls = '';
      if (isAnswered) cls = correct ? 'correct' : (picked === i ? 'wrong' : '');
      return `<button class="quiz-opt ${cls}" ${isAnswered ? 'disabled' : ''} onclick="answerRich(${day},${i},this)">${text}</button>`;
    }).join('');
    const expClass = isAnswered ? 'show' : '';
    const ansText = it.ans || '';
    const expText = it.exp || '';
    html = `<div class="quiz-block">
      <div class="quiz-question">${it.q}</div>
      <div class="quiz-opts" id="rich-opts-${day}">${optHTML}</div>
      <div class="quiz-explanation ${expClass}" id="rich-exp-${day}">${ansText}${expText ? '　' + expText : ''}</div>
    </div>`;

  } else if (it.type === 'dragSort') {
    const items = it.opts || [];
    const hint = it.ans || '';
    const pickedYang = (saved && saved.yangPicks) || [];
    const pickedYin = (saved && saved.yinPicks) || [];
    const itemHTML = items.map((item, i) => {
      const inYang = pickedYang.includes(i);
      const inYin = pickedYin.includes(i);
      const cls = inYang ? 'choice-opt selected' : inYin ? 'choice-opt selected' : 'choice-opt';
      const tag = inYang ? ' ☀' : inYin ? ' ☽' : '';
      return `<button class="${cls}" onclick="sortYinYang(${day},${i},this)">${item}${tag}</button>`;
    }).join('');
    html = `<div class="content-interaction-desc" style="margin-bottom:8px">點擊歸類（第一次 = 陽，第二次 = 陰，第三次 = 取消）</div>
      <div class="choice-grid" id="sort-${day}">${itemHTML}</div>
      <div style="margin-top:8px;font-size:0.7857em;color:var(--text-dim);font-weight:300">${hint}</div>`;

  } else if (it.type === 'eightCards') {
    const GUA = ['乾','坤','震','巽','坎','離','艮','兌'];
    const SYM = ['☰','☷','☳','☴','☵','☲','☶','☱'];
    const items = it.opts || [];
    const flipped = (saved && saved.flipped) || [];
    const cardHTML = items.map((item, i) => {
      const isFlipped = flipped.includes(i);
      const parts = item.split('：');
      const front = SYM[i] || parts[0];
      const back = item;
      return `<div class="gua-card${isFlipped ? ' flipped' : ''}" onclick="flipCard(${day},${i},this)">
        <div class="gua-card-front">${front}</div>
        <div class="gua-card-back">${back}</div>
      </div>`;
    }).join('');
    html = `<div class="gua-card-grid">${cardHTML}</div>`;

  } else if (it.type === 'trigramBuilder') {
    const yao = (saved && saved.yao) || [1, 1, 1];
    const rows = [2, 1, 0].map(i => {
      const isYang = yao[i];
      return `<div class="yao-toggle">
        <button class="yao-btn" onclick="toggleYao(${day},${i},this)">${isYang ? '—' : '- -'}</button>
        <span class="yao-label">第 ${i + 1} 爻</span>
      </div>`;
    }).join('');
    const key = yao.map(v => v ? '1' : '0').join('');
    const gua = GUA_MAP[key];
    html = `<div class="line-builder">${rows}</div>
      <div class="gua-result" id="gua-result-${day}">${gua ? gua.symbol + ' ' + gua.name + '卦' : '組合中…'}</div>`;

  } else if (it.type === 'hexagramComposer') {
    const guaNames = ['乾','坤','震','巽','坎','離','艮','兌'];
    const guaSyms = ['☰','☷','☳','☴','☵','☲','☶','☱'];
    const upperIdx = (saved && saved.hcUpper !== undefined) ? saved.hcUpper : null;
    const lowerIdx = (saved && saved.hcLower !== undefined) ? saved.hcLower : null;
    const makeOpts = (which) => guaNames.map((g, i) => {
      const val = which === 'upper' ? upperIdx : lowerIdx;
      const sel = val === i ? 'choice-opt selected' : 'choice-opt';
      return `<button class="${sel}" onclick="selectHC(${day},'${which}',${i},this)">${guaSyms[i]}${g}</button>`;
    }).join('');
    const resultText = (upperIdx !== null && lowerIdx !== null)
      ? `${guaSyms[upperIdx]}${guaNames[upperIdx]}（上）+ ${guaSyms[lowerIdx]}${guaNames[lowerIdx]}（下）`
      : '請選擇上卦與下卦';
    html = `<div style="margin-bottom:8px">
      <div style="font-size:0.7143em;color:var(--text-dim);letter-spacing:0.1em;margin-bottom:5px;font-weight:700">上卦</div>
      <div class="choice-grid">${makeOpts('upper')}</div>
    </div>
    <div style="margin-bottom:8px">
      <div style="font-size:0.7143em;color:var(--text-dim);letter-spacing:0.1em;margin-bottom:5px;font-weight:700">下卦</div>
      <div class="choice-grid">${makeOpts('lower')}</div>
    </div>
    <div style="font-size:0.8571em;color:var(--text);font-weight:300;padding:8px 0" id="hc-result-${day}">${resultText}</div>`;

  } else if (it.type === 'guidedPractice') {
    const steps = it.opts || [];
    const doneSteps = (saved && saved.gpDone) || [];
    const stepHTML = steps.map((s, i) => {
      const done = doneSteps.includes(i);
      return `<div class="gp-step${done ? ' done' : ''}" onclick="toggleGP(${day},${i},this)">
        <div class="gp-check">${done ? '✓' : ''}</div>
        <span>${s}</span>
      </div>`;
    }).join('');
    html = `<div class="gp-steps">${stepHTML}</div>`;
  }

  if (!html) return '';

  return `<div class="content-block">
    <div class="content-block-label">${it.title || '今日互動'}</div>
    <div class="content-interaction-desc" style="margin-bottom:8px">${it.q}</div>
    ${html}
    ${it.ans && it.type !== 'multipleChoice' ? `<div style="font-size:0.7857em;color:var(--text-dim);margin-top:8px;font-weight:300">${it.ans}</div>` : ''}
  </div>`;
}

function answerRich(day, idx, btn) {
  const rich = RICH.find(d => d.day === day);
  if (!rich) return;
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey].richAnswered = true;
  state[stateKey].richPick = idx;
  saveState(state);
  const opts = btn.closest('.quiz-opts').querySelectorAll('.quiz-opt');
  opts.forEach((b, i) => {
    b.disabled = true;
    const o = rich.it.opts[i];
    const correct = typeof o === 'object' ? o.ok : false;
    if (correct) b.classList.add('correct');
    else if (i === idx) b.classList.add('wrong');
  });
  const exp = document.getElementById(`rich-exp-${day}`);
  if (exp) exp.classList.add('show');
}

function sortYinYang(day, idx, btn) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  let yang = state[stateKey].yangPicks || [];
  let yin = state[stateKey].yinPicks || [];
  if (yang.includes(idx)) {
    yang = yang.filter(i => i !== idx);
    yin = [...yin, idx];
  } else if (yin.includes(idx)) {
    yin = yin.filter(i => i !== idx);
  } else {
    yang = [...yang, idx];
  }
  state[stateKey].yangPicks = yang;
  state[stateKey].yinPicks = yin;
  saveState(state);
  const rich = RICH.find(d => d.day === day);
  renderTodayContent(day);
}

function flipCard(day, idx, el) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  let flipped = state[stateKey].flipped || [];
  if (flipped.includes(idx)) flipped = flipped.filter(i => i !== idx);
  else flipped = [...flipped, idx];
  state[stateKey].flipped = flipped;
  saveState(state);
  el.classList.toggle('flipped');
}

function selectHC(day, which, idx, btn) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey][which === 'upper' ? 'hcUpper' : 'hcLower'] = idx;
  saveState(state);
  renderTodayContent(day);
}

function toggleGP(day, idx, el) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  let done = state[stateKey].gpDone || [];
  if (done.includes(idx)) done = done.filter(i => i !== idx);
  else done = [...done, idx];
  state[stateKey].gpDone = done;
  saveState(state);
  el.classList.toggle('done');
  el.querySelector('.gp-check').textContent = done.includes(idx) ? '✓' : '';
}

function toggleAcc(header) {
  const body = header.nextElementSibling;
  const arrow = header.querySelector('.acc-arrow');
  const isOpen = body.classList.toggle('open');
  arrow.classList.toggle('open', isOpen);
}

function answerQuiz(day, idx, btn) {
  const course = COURSE.find(d => d.day === day);
  if (!course || !course.quiz) return;
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey].quizAnswered = true;
  state[stateKey].quizPick = idx;
  saveState(state);

  const opts = btn.closest('.quiz-opts').querySelectorAll('.quiz-opt');
  opts.forEach((b, i) => {
    b.disabled = true;
    if (course.quiz.opts[i] === course.quiz.ans) b.classList.add('correct');
    else if (i === idx) b.classList.add('wrong');
  });
  const exp = document.getElementById(`quiz-exp-${day}`);
  if (exp) exp.classList.add('show');
}

function toggleContent(day) {
  const body = document.getElementById(`content-body-${day}`);
  const icon = document.getElementById(`content-toggle-${day}`);
  const isOpen = body.classList.toggle('open');
  icon.classList.toggle('open', isOpen);
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey].open = isOpen;
  saveState(state);
}

function selectChoice(day, idx, btn) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey].choice = idx;
  saveState(state);
  btn.closest('.choice-grid').querySelectorAll('.choice-opt').forEach((b,i) => {
    b.classList.toggle('selected', i === idx);
  });
}

function toggleYao(day, yaoIdx, btn) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  let yao = state[stateKey].yao || [1,1,1];
  yao[yaoIdx] = yao[yaoIdx] ? 0 : 1;
  state[stateKey].yao = yao;
  saveState(state);
  btn.textContent = yao[yaoIdx] ? '—' : '- -';
  const key = yao.map(v => v ? '1' : '0').join('');
  const gua = GUA_MAP[key];
  const el = document.getElementById(`gua-result-${day}`);
  if (el) el.textContent = gua ? `${gua.symbol} ${gua.name}卦` : '組合中…';
}

function throwCoin(day, idx) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  let yao = state[stateKey].coinYao || [];
  yao[idx] = Math.random() < 0.5 ? 1 : 0;
  state[stateKey].coinYao = yao;
  saveState(state);
  renderTodayContent(day);
}

function resetCoin(day) {
  const stateKey = `interact_${day}`;
  state[stateKey] = state[stateKey] || {};
  state[stateKey].coinYao = [];
  saveState(state);
  renderTodayContent(day);
}

