function renderReview() {
  const container = document.getElementById('review-list');
  const days = Object.keys(state.diaries)
    .filter(k => state.diaries[k]?.savedAt)
    .map(Number)
    .sort((a, b) => b - a);

  if (!days.length) {
    container.innerHTML = `<div class="empty-state"><div class="icon">冊</div>尚無已儲存的日記</div>`;
    return;
  }

  container.innerHTML = `<div class="review-grid">` + days.map(day => {
    const entry = state.diaries[day];
    const task = TASKS[day - 1];
    const preview = entry.learned || entry.gua || '（無內容）';
    return `
      <div class="review-card" onclick="openDiaryDay(${day})">
        <div class="review-card-day">
          <span class="review-card-tag"></span>
          第 ${day} 天｜${entry.savedAt?.slice(0,10) || ''}
        </div>
        <div class="review-card-title">${task.name.slice(0,-1)}</div>
        <div class="review-card-preview">${preview}</div>
      </div>
    `;
  }).join('') + `</div>`;
}

function openDiaryDay(day) {
  currentDiaryDay = day;
  navigateTo('diary');
}

