}

// ── Page: Tasks ───────────────────────────────────────────────────────

function renderTaskList() {
  const container = document.getElementById('task-list');
  const filtered = TASKS.filter(t => {
    if (currentFilter === 'done') return state.tasks[t.day]?.done;
    if (currentFilter === 'undone') return !state.tasks[t.day]?.done;
    if (currentFilter === 'week1') return t.week === 1;
    if (currentFilter === 'week2') return t.week === 2;
    if (currentFilter === 'week3') return t.week === 3;
    if (currentFilter === 'week4') return t.week === 4;
    return true;
  });

  if (!filtered.length) {
    container.innerHTML = `<div class="empty-state"><div class="icon">○</div>目前沒有符合條件的任務</div>`;
    return;
  }

  container.innerHTML = filtered.map(task => {
    const ts = state.tasks[task.day] || {};
    const done = !!ts.done;
    return `
      <div class="task-item ${done ? 'completed' : ''}" id="task-item-${task.day}">
        <div class="task-check ${done ? 'checked' : ''}" onclick="toggleTask(${task.day})"></div>
        <div class="task-info">
          <div class="task-name">第 ${task.day} 天｜${task.name.slice(0, -1)}</div>
          <div class="task-meta-row">
            <span class="week-badge ${WEEK_CLASS[task.week]}">${WEEK_NAMES[task.week]}</span>
            <span class="task-meta-item">${task.theme}</span>
            ${ts.doneAt ? `<span class="task-done-time">完成於 ${ts.doneAt.slice(0,10)}</span>` : ''}
          </div>
          <textarea class="task-note-input" placeholder="備註……" onblur="saveTaskNote(${task.day}, this)">${ts.note || ''}</textarea>
        </div>
      </div>
    `;
  }).join('');
}

function toggleTask(day) {
  const t = state.tasks[day] || {};
  t.done = !t.done;
  if (t.done) t.doneAt = new Date().toISOString();
  else delete t.doneAt;
  state.tasks[day] = t;
  saveState(state);
  renderStats();
  renderTaskList();
  if (day === getTodayDay()) renderToday();
}

function saveTaskNote(day, el) {
  const t = state.tasks[day] || {};
  t.note = el.value;
  state.tasks[day] = t;
  saveState(state);
}

