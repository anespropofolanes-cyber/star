<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="易經三十日">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#1a1a1c">
  <link rel="apple-touch-icon" href="data:image/png;base64,">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>易經三十日｜每日學習</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;700&family=Noto+Sans+TC:wght@300;400;700&display=swap');

  :root {
    --bg:        #eeede9;
    --bg2:       #ffffff;
    --bg3:       #f5f4f0;
    --border:    #d8d8d2;
    --border2:   #c0c0b8;
    --text:      #1c1c1c;
    --text-mid:  #666660;
    --text-dim:  #aaaaaa;
    --white:     #ffffff;
    --accent:    #222222;
    --accent2:   #888880;
    --done:      #3d6b50;
    --done-bg:   rgba(61,107,80,0.07);
    --sb-bg:     #1a1a1c;
    --sb-border: #2c2c30;
    --sb-text:   #909098;
    --sb-dim:    #484850;
    --radius:    3px;
    --shadow:    0 1px 4px rgba(0,0,0,0.06);
    --fs: 14px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans TC', 'PingFang TC', 'Microsoft JhengHei', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: var(--fs);
    line-height: 1.75;
    min-height: 100vh;
    font-weight: 300;
  }

  /* ── Stars canvas ── */
  #stars-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .app {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  /* ── Topbar wrapper (sticky both rows) ── */
  .topbar-wrapper {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--sb-bg);
  }

  /* ── Brand bar (top row) ── */
  .topbar-brand-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-bottom: 1px solid var(--sb-border);
  }

  .topbar-logo {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: invert(1) brightness(0.85);
    flex-shrink: 0;
  }

  .topbar-brand-bar h1 {
    font-family: 'Noto Serif TC', serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--white);
    white-space: nowrap;
  }

  .topbar-brand-sub {
    font-size: 10px;
    color: var(--sb-dim);
    font-weight: 300;
    letter-spacing: 0.08em;
  }

  /* ── Topbar nav row (bottom row) ── */
  .topbar {
    background: var(--sb-bg);
    border-bottom: 1px solid var(--sb-border);
    display: flex;
    align-items: center;
    height: 44px;
    padding: 0;
    overflow: hidden;
  }

  .topbar-nav {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 4px;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 16px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    font-weight: 300;
    color: var(--sb-text);
    transition: all 0.15s;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-btn:hover { color: var(--white); background: rgba(255,255,255,0.04); }
  .nav-btn.active {
    color: var(--white);
    border-bottom-color: #c8c8c0;
    font-weight: 700;
  }

  .topbar-stats {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 20px;
    border-left: 1px solid var(--sb-border);
    flex-shrink: 0;
    height: 100%;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .stat-label {
    font-size: 8px;
    color: var(--sb-dim);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
  }

  .stat-val {
    font-size: 13px;
    font-weight: 700;
    font-family: 'Noto Serif TC', serif;
    color: var(--white);
    line-height: 1.2;
    white-space: nowrap;
  }

  .topbar-progress {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }

  .progress-bar-wrap {
    width: 52px;
    height: 2px;
    background: var(--sb-border);
    border-radius: 1px;
  }

  .progress-bar-fill {
    height: 100%;
    background: #b0b0a8;
    border-radius: 1px;
    transition: width 0.6s ease;
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }

  /* ── Main ── */
  .main {
    flex: 1;
    padding: 40px 48px;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    background: var(--bg);
    box-sizing: border-box;
  }

  .page { display: none; }
  .page.active { display: block; }

  /* ── Header ── */
  .page-header {
    margin-bottom: 32px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--border);
  }

  .page-header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .page-title {
    font-family: 'Noto Serif TC', serif;
    font-size: 1.7143em;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text);
  }

  .page-subtitle {
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 4px;
    letter-spacing: 0.06em;
    font-weight: 300;
  }

  .today-quote {
    background: rgba(0,0,0,0.03);
    border-left: 2px solid var(--border2);
    padding: 12px 18px;
    margin-top: 18px;
    font-family: 'Noto Serif TC', serif;
    font-size: 0.9286em;
    font-weight: 300;
    color: var(--text-mid);
    letter-spacing: 0.06em;
  }

  /* ── Today content card ── */
  .content-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-bottom: 28px;
  }
  .content-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    user-select: none;
  }
  .content-card-header-left { display: flex; align-items: center; gap: 12px; }
  .content-symbol { font-size: 1.5714em; line-height: 1; color: var(--text); font-family: 'Noto Serif TC', serif; }
  .content-day-label { font-size: 9px; letter-spacing: 0.14em; color: var(--text-dim); text-transform: uppercase; font-weight: 300; margin-bottom: 2px; }
  .content-card-title { font-family: 'Noto Serif TC', serif; font-size: 1.0714em; font-weight: 700; color: var(--text); letter-spacing: 0.04em; }
  .content-keyword { font-size: 10px; color: var(--text-dim); letter-spacing: 0.1em; border: 1px solid var(--border2); padding: 2px 8px; border-radius: 1px; font-weight: 300; }
  .content-toggle-icon { font-size: 11px; color: var(--text-dim); transition: transform 0.2s; }
  .content-toggle-icon.open { transform: rotate(180deg); }
  .content-body { display: none; padding: 20px 22px; }
  .content-body.open { display: block; }
  .content-block { margin-bottom: 18px; }
  .content-block:last-child { margin-bottom: 0; }
  .content-block-label { font-size: 9px; letter-spacing: 0.16em; color: var(--text-dim); text-transform: uppercase; font-weight: 700; margin-bottom: 6px; }
  .content-block-text { font-size: 0.9286em; font-weight: 300; color: var(--text); line-height: 1.85; }
  .content-quote-block { background: var(--bg3); border-left: 2px solid var(--border2); padding: 10px 16px; margin-top: 16px; font-family: 'Noto Serif TC', serif; font-size: 0.9286em; font-weight: 300; color: var(--text-mid); letter-spacing: 0.04em; }
  .content-interaction { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; margin-top: 4px; }
  .content-interaction-title { font-size: 11px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
  .content-interaction-desc { font-size: 11px; color: var(--text-mid); font-weight: 300; line-height: 1.6; }
  /* choice */
  .choice-grid { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .choice-opt { padding: 6px 14px; border: 1px solid var(--border2); border-radius: 1px; background: #fff; font-family: inherit; font-size: 0.8571em; font-weight: 300; color: var(--text); cursor: pointer; transition: all 0.15s; }
  .choice-opt:hover { border-color: var(--accent2); }
  .choice-opt.selected { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 700; }
  /* lineBuilder */
  .line-builder { margin-top: 10px; display: flex; flex-direction: column; gap: 8px; }
  .yao-toggle { display: flex; align-items: center; gap: 10px; }
  .yao-btn { padding: 6px 20px; border: 1px solid var(--border2); border-radius: 1px; background: #fff; font-family: 'Noto Serif TC', serif; font-size: 0.9286em; cursor: pointer; color: var(--text); min-width: 60px; text-align: center; transition: all 0.15s; }
  .yao-btn:hover { background: var(--bg3); }
  .yao-label { font-size: 10px; color: var(--text-dim); font-weight: 300; }
  .gua-result { font-size: 1.8571em; font-family: 'Noto Serif TC', serif; margin-top: 6px; color: var(--text); }
  /* sections accordion */
  .section-accordion { margin-top: 4px; display: flex; flex-direction: column; gap: 4px; }
  .acc-item { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .acc-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; cursor: pointer; background: var(--bg3); user-select: none;
    font-size: 0.8571em; font-weight: 700; color: var(--text); letter-spacing: 0.03em;
    transition: background 0.12s;
  }
  .acc-header:hover { background: var(--border); }
  .acc-arrow { font-size: 10px; color: var(--text-dim); transition: transform 0.2s; flex-shrink: 0; }
  .acc-arrow.open { transform: rotate(180deg); }
  .acc-body { display: none; padding: 12px 14px; background: var(--bg2); }
  .acc-body.open { display: block; }
  .acc-para {
    font-size: 0.9286em; font-weight: 300; color: var(--text); line-height: 1.85;
    margin-bottom: 8px;
  }
  .acc-para:last-child { margin-bottom: 0; }
  /* special headings */
  .acc-item.is-quote .acc-body { background: var(--bg3); border-left: 2px solid var(--border2); }
  .acc-item.is-quote .acc-para { font-family: 'Noto Serif TC', serif; color: var(--text-mid); }
  .acc-item.is-case .acc-header { background: rgba(61,107,80,0.06); }

  /* gua card grid */
  .gua-card-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 6px; }
  .gua-card {
    aspect-ratio: 1;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    background: var(--bg2);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    transition: border-color 0.15s;
  }
  .gua-card:hover { border-color: var(--accent2); }
  .gua-card-front {
    font-size: 1.5714em; color: var(--text);
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%;
  }
  .gua-card-back {
    display: none;
    font-size: 11px; font-weight: 300; color: var(--text);
    text-align: center; padding: 4px; line-height: 1.5;
    width: 100%; height: 100%;
    align-items: center; justify-content: center;
  }
  .gua-card.flipped { background: var(--accent); border-color: var(--accent); }
  .gua-card.flipped .gua-card-front { display: none; }
  .gua-card.flipped .gua-card-back { display: flex; color: #fff; }

  /* guided practice steps */
  .gp-steps { display: flex; flex-direction: column; gap: 6px; margin-top: 6px; }
  .gp-step {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg2);
    cursor: pointer;
    font-size: 0.8571em; font-weight: 300; color: var(--text);
    transition: all 0.15s;
  }
  .gp-step:hover { border-color: var(--accent2); }
  .gp-step.done { background: var(--done-bg); border-color: rgba(61,107,80,0.3); color: var(--done); }
  .gp-check {
    width: 18px; height: 18px; min-width: 18px;
    border: 1px solid var(--border2);
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    background: transparent; transition: all 0.15s;
  }
  .gp-step.done .gp-check { background: var(--done); border-color: var(--done); }
  .goals-list { display: flex; flex-direction: column; gap: 5px; margin-top: 4px; }
  .goal-item { display: flex; align-items: flex-start; gap: 8px; font-size: 0.8571em; font-weight: 300; color: var(--text); line-height: 1.6; }
  .goal-item::before { content: '○'; color: var(--text-dim); flex-shrink: 0; font-size: 10px; margin-top: 3px; }
  .quiz-block { margin-top: 6px; }
  .quiz-question { font-size: 0.9286em; font-weight: 300; color: var(--text); line-height: 1.7; margin-bottom: 10px; }
  .quiz-opts { display: flex; flex-direction: column; gap: 6px; }
  .quiz-opt {
    padding: 9px 14px;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    background: var(--bg2);
    font-family: inherit;
    font-size: 0.8571em;
    font-weight: 300;
    color: var(--text);
    cursor: pointer;
    text-align: left;
    transition: all 0.15s;
    line-height: 1.5;
  }
  .quiz-opt:hover:not([disabled]) { border-color: var(--accent2); background: var(--bg3); }
  .quiz-opt.correct { background: var(--done-bg); border-color: var(--done); color: var(--done); font-weight: 700; }
  .quiz-opt.wrong { background: rgba(180,60,60,0.06); border-color: rgba(180,60,60,0.4); color: #8b3030; }
  .quiz-opt[disabled] { cursor: default; }
  .quiz-explanation {
    margin-top: 10px;
    padding: 10px 14px;
    background: var(--bg3);
    border-left: 2px solid var(--done);
    font-size: 0.8571em;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.6;
    display: none;
  }
  .quiz-explanation.show { display: block; }
  /* practice list */
  .practice-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .practice-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.8571em;
    font-weight: 300;
    color: var(--text);
    line-height: 1.6;
  }
  .practice-item::before { content: '›'; color: var(--text-dim); flex-shrink: 0; margin-top: 1px; }
  /* goal */
  .goal-block {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
    font-size: 0.9286em;
    font-weight: 300;
    color: var(--text);
    line-height: 1.7;
    margin-top: 4px;
  }
  .coin-rows { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
  .coin-row-item { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--text-mid); font-weight: 300; }
  .coin-throw-btn { padding: 5px 14px; border: 1px solid var(--border2); border-radius: 1px; background: #fff; font-family: inherit; font-size: 11px; cursor: pointer; color: var(--text); transition: all 0.15s; }
  .coin-throw-btn:hover { background: var(--bg3); }
  .coin-yao { font-size: 1.1429em; font-family: 'Noto Serif TC', serif; min-width: 20px; }
  .coin-yao.yang { color: var(--text); }
  .coin-yao.yin { color: var(--text-mid); }

  .topbar-controls {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }

  .ctrl-btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--sb-border);
    background: rgba(255,255,255,0.06);
    color: var(--sb-text);
    cursor: pointer;
    font-size: 12px;
    font-family: 'Noto Serif TC', serif;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s;
    flex-shrink: 0;
  }

  .ctrl-btn:hover {
    background: rgba(255,255,255,0.14);
    color: var(--white);
    border-color: rgba(255,255,255,0.3);
  }

  .ctrl-btn.active {
    background: rgba(255,255,255,0.18);
    color: var(--white);
    border-color: rgba(255,255,255,0.4);
  }

  .ctrl-btn.size-btn {
    width: 36px;
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
  }

  /* ── Font modes ── */
  body.font-serif {
    font-family: 'Noto Serif TC', 'STSong', 'BiauKai', serif;
  }

  /* ── Dark / Cosmic mode ── */
  body.dark-mode {
    --bg:       #090914;
    --bg2:      #13132a;
    --bg3:      #1a1a36;
    --border:   #252545;
    --border2:  #323260;
    --text:     #e8eaff;
    --text-mid: #9898cc;
    --text-dim: #5858a0;
    --accent:   #a090ff;
    --accent2:  #6655cc;
    --done:     #55d499;
    --done-bg:  rgba(85,212,153,0.08);
    --shadow:   0 4px 24px rgba(0,0,20,0.6);
  }

  body.dark-mode .topbar-wrapper { background: #020208; }
  body.dark-mode .topbar { background: #020208; border-bottom-color: #0f0f28; }
  body.dark-mode .topbar-brand-bar { border-bottom-color: #0f0f28; }

  /* Cosmic glow effects in dark mode */
  body.dark-mode .today-card,
  body.dark-mode .content-card,
  body.dark-mode .diary-card,
  body.dark-mode .review-card {
    background: #13132a !important;
    border-color: #252545 !important;
    box-shadow: 0 0 0 1px rgba(100,80,220,0.18), 0 4px 28px rgba(40,20,120,0.2);
  }

  body.dark-mode .progress-bar-fill {
    background: linear-gradient(90deg, #5533dd, #9966ff, #cc88ff);
    box-shadow: 0 0 14px rgba(150,100,255,0.8), 0 0 4px rgba(200,150,255,0.5);
  }

  body.dark-mode .today-quote {
    border-left-color: #6644cc;
    background: rgba(80,60,180,0.1);
    color: #b8aaee;
    letter-spacing: 0.06em;
  }

  body.dark-mode .task-check.checked {
    background: var(--done);
    border-color: var(--done);
    box-shadow: 0 0 10px rgba(85,212,153,0.6), 0 0 4px rgba(85,212,153,0.4);
  }

  body.dark-mode .acc-header {
    background: rgba(22,20,52,0.98);
    color: var(--text);
  }
  body.dark-mode .acc-header:hover { background: rgba(32,28,66,1); }
  body.dark-mode .acc-item.is-quote .acc-body { border-left-color: #6644cc; background: rgba(40,28,90,0.35); }
  body.dark-mode .acc-item.is-case .acc-header { background: rgba(16,34,28,0.95); }

  body.dark-mode .diary-day-cell {
    background: rgba(20,20,44,0.9);
    border-color: #252550;
  }

  body.dark-mode .diary-day-cell.active {
    background: linear-gradient(135deg, #3322aa, #6644cc, #8855ee);
    border-color: #8855ee;
    box-shadow: 0 0 16px rgba(120,80,240,0.5), 0 0 6px rgba(180,140,255,0.3);
  }

  body.dark-mode .btn-primary {
    background: linear-gradient(135deg, #5533cc, #8855ee);
    box-shadow: 0 2px 16px rgba(100,60,240,0.4);
  }
  body.dark-mode .btn-primary:hover { background: linear-gradient(135deg, #6644dd, #9966ff); }

  body.dark-mode .filter-btn.active {
    background: linear-gradient(135deg, #5533cc, #8855ee);
    border-color: #9966ff;
    color: #fff;
    box-shadow: 0 0 10px rgba(100,60,240,0.35);
  }

  body.dark-mode .gua-card { background: rgba(20,20,44,0.95); border-color: #282860; }
  body.dark-mode .gua-card.flipped {
    background: linear-gradient(135deg, #221166, #5533bb);
    box-shadow: 0 0 20px rgba(80,40,200,0.5), 0 0 8px rgba(160,100,255,0.3);
  }

  body.dark-mode .quiz-opt {
    background: rgba(18,18,40,0.95);
    border-color: #282860;
    color: var(--text);
  }
  body.dark-mode .quiz-opt:hover:not([disabled]) {
    border-color: #7755dd;
    background: rgba(40,28,88,0.7);
  }
